{
  "schema": 1,
  "name": "Opal Plugins",
  "description": "Source endpoints for Opal. The app holds the connector code; these supply the URLs and enable the source. Installing writes ~/.config/zigzag/plugins/sources/<id>.json — torrent ids match the nova2 engine that runs them.",
  "plugins": [
    { "id": "apibay",         "name": "The Pirate Bay",  "type": "torrent", "version": "1.0.0", "endpoints": { "base": "https://apibay.org" } },
    { "id": "one337x",        "name": "1337x",           "type": "torrent", "version": "1.0.0", "endpoints": { "base": "https://1337x.to" } },
    { "id": "yts",            "name": "YTS (movies)",    "type": "torrent", "version": "1.0.0", "endpoints": { "base": "https://yts.mx", "api": "https://yts.mx/api/v2/list_movies.json" } },
    { "id": "eztv",           "name": "EZTV (TV)",       "type": "torrent", "version": "1.0.0", "endpoints": { "base": "https://eztvx.to", "api": "https://eztvx.to/api/get-torrents" } },
    { "id": "nyaa",           "name": "Nyaa (anime)",    "type": "torrent", "version": "1.0.0", "endpoints": { "base": "https://nyaa.si" } },
    { "id": "kickass",        "name": "KickAss",         "type": "torrent", "version": "1.0.0", "endpoints": { "base": "https://kickasstorrents.to" } },
    { "id": "limetorrents",   "name": "LimeTorrents",    "type": "torrent", "version": "1.0.0", "endpoints": { "base": "https://www.limetorrents.lol" } },
    { "id": "torlock",        "name": "TorLock",         "type": "torrent", "version": "1.0.0", "endpoints": { "base": "https://www.torlock.com" } },
    { "id": "torrentproject", "name": "TorrentProject",  "type": "torrent", "version": "1.0.0", "endpoints": { "base": "https://torrentproject2.net" } },
    { "id": "torrentscsv",    "name": "Torrents-CSV",    "type": "torrent", "version": "1.0.0", "endpoints": { "base": "https://torrents-csv.com" } },
    { "id": "solidtorrents",  "name": "SolidTorrents",   "type": "torrent", "version": "1.0.0", "endpoints": { "base": "https://solidtorrents.to" } },
