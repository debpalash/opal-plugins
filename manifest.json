    { "id": "jackett",        "name": "Jackett (self-hosted)", "type": "torrent", "version": "1.0.0", "endpoints": { "base": "http://127.0.0.1:9117" } },
    { "id": "readallcomics",  "name": "ReadAllComics",   "type": "comics",  "version": "1.0.0", "endpoints": { "base": "https://readallcomics.com" } },
    { "id": "animepahe",      "name": "AnimePahe",       "type": "anime",   "version": "1.0.0", "endpoints": { "base": "https://animepahe.pw" } }
  ]
